<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>

<StackPane fx:id="parent"
           prefWidth="100.0" prefHeight="100.0"
           maxWidth="100.0" maxHeight="100.0"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dat055.group5.client.controller.ImageListItemController">

    <ImageView fx:id="imgView"
               fitWidth="100.0" fitHeight="100.0"
               preserveRatio="true" />

    <Button onAction="#onClose"
            text="x"
            StackPane.alignment="TOP_RIGHT"
            style="-fx-background-color: rgba(255,255,255,0.8); -fx-font-weight: bold;"/>
</StackPane>