<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>

<StackPane fx:id="parent"
           prefWidth="125.0" prefHeight="125.0"
           maxWidth="125.0" maxHeight="125.0"
           minWidth="125.0" minHeight="125.0"
           style="-fx-background-color: rgba(0,0,0,0.08); -fx-background-radius: 12;"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dat055.group5.client.controller.ImageListItemController">

    <ImageView fx:id="imgView"
               fitWidth="100.0" fitHeight="100.0"
               preserveRatio="true"/>

    <Button onAction="#onClose"
            text="X"
            StackPane.alignment="TOP_RIGHT"
            style="
                -fx-background-color: red;
                -fx-text-fill: white;
                -fx-font-size: 10px;">
                <StackPane.margin>
                    <Insets top="6.0" right="6.0"/>
                </StackPane.margin>
    </Button>
</StackPane>